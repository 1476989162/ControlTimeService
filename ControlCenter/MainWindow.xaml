<Window x:Class="ControlCenter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="时间控制管理中心"
        Height="600"
        Width="1000">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 工具栏 -->
        <StackPanel Grid.Row="0" 
                    Orientation="Horizontal" 
                    Margin="0,0,0,10">
            <Button Content="刷新客户端列表" 
                    Width="120" 
                    Height="30" 
                    Margin="5"
                    Click="RefreshButton_Click"/>
            <Button Content="远程锁定"
                    Width="90"
                    Height="30"
                    Margin="5"
                    Click="LockClient_Click"/>
            <Button Content="远程解锁"
                    Width="90"
                    Height="30"
                    Margin="5"
                    Click="UnlockClient_Click"/>
            <Button Content="暂停计时"
                    Width="90"
                    Height="30"
                    Margin="5"
                    Click="PauseClient_Click"/>
            <Button Content="发送消息"
                    Width="90"
                    Height="30"
                    Margin="5"
                    Click="SendMessage_Click"/>
            <Button Content="客户端设置"
                    Width="90"
                    Height="30"
                    Margin="5"
                    Click="EditClientSettings_Click"/>
            <Button Content="启动服务器"
                    x:Name="StartServerBtn"
                    Width="100" 
                    Height="30" 
                    Margin="5"
                    Click="StartServerButton_Click"/>
            <TextBlock Text="监听端口:"
                       VerticalAlignment="Center"
                       Margin="10,0,5,0"/>
            <TextBox x:Name="ListenPortText"
                     Width="60"
                     Height="24"
                     VerticalAlignment="Center"
                     Text="9528"
                     ToolTip="默认 9528，若被占用可改为 19528 等"/>
            <TextBlock Text="服务器状态:" 
                       VerticalAlignment="Center" 
                       Margin="20,0,5,0"/>
            <TextBlock x:Name="ServerStatusText" 
                       Text="未启动" 
                       Foreground="Red"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <!-- 客户端连接提示 -->
        <Border Grid.Row="1" Background="#FFF8F0" BorderBrush="#FFD8A8" BorderThickness="1"
                CornerRadius="4" Padding="8,6" Margin="0,0,0,8">
            <StackPanel>
                <TextBlock Text="客户端连接地址（写入 control_config.json 的 server_url）："
                           FontWeight="SemiBold" Margin="0,0,0,4"/>
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="ClientUrlHintText"
                               Text="服务器未启动"
                               VerticalAlignment="Center"
                               Foreground="#333"/>
                    <Button Content="复制"
                            Width="50" Height="22" Margin="10,0,0,0"
                            Click="CopyClientUrl_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- 升级配置 -->
        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="90"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="升级包地址:"
                       VerticalAlignment="Center"
                       Margin="5,0"/>
            <TextBox x:Name="UpdatePackageUrlText"
                     Grid.Column="1"
                     Margin="5,0"
                     VerticalAlignment="Center"
                     ToolTip="ZIP 升级包 HTTP/HTTPS 地址"/>
            <TextBlock Grid.Column="2"
                       Text="版本:"
                       VerticalAlignment="Center"
                       Margin="10,0,5,0"/>
            <TextBox x:Name="UpdateVersionText"
                     Grid.Column="3"
                     Margin="0,0,5,0"
                     VerticalAlignment="Center"
                     ToolTip="例如 1.0.1"/>
            <TextBlock Grid.Column="4"
                       Text="清单地址:"
                       VerticalAlignment="Center"
                       Margin="5,0"/>
            <TextBox x:Name="UpdateManifestUrlText"
                     Grid.Column="5"
                     Grid.ColumnSpan="1"
                     Width="180"
                     Margin="5,0"
                     VerticalAlignment="Center"
                     ToolTip="可选，自动检查更新用的 manifest.json 地址"/>
            <Button Grid.Column="6"
                    Content="保存配置"
                    Height="30"
                    Margin="5,0"
                    Click="SaveUpdateConfig_Click"/>
            <Button Grid.Column="7"
                    Content="推送升级"
                    Height="30"
                    Margin="5,0"
                    Click="PushUpdate_Click"/>
        </Grid>

        <!-- 客户端列表 -->
        <DataGrid Grid.Row="3"
                  x:Name="ClientsDataGrid" 
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="电脑名称" 
                                    Binding="{Binding Name}" 
                                    Width="140"/>
                <DataGridTextColumn Header="IP地址" 
                                    Binding="{Binding IpAddress}" 
                                    Width="110"/>
                <DataGridTextColumn Header="状态" 
                                    Binding="{Binding Status}" 
                                    Width="70"/>
                <DataGridTextColumn Header="首次上线" 
                                    Binding="{Binding FirstSeen, StringFormat=yyyy-MM-dd HH:mm}" 
                                    Width="130"/>
                <DataGridTextColumn Header="版本"
                                    Binding="{Binding AppVersion}"
                                    Width="80"/>
                <DataGridTextColumn Header="剩余时间" 
                                    Binding="{Binding RemainingTimeDisplay}" 
                                    Width="100"/>
                <DataGridTextColumn Header="今日已用(小时)" 
                                    Binding="{Binding TotalUsageHoursToday, StringFormat={}{0:N1}}" 
                                    Width="120"/>
                <DataGridTextColumn Header="最后心跳" 
                                    Binding="{Binding LastHeartbeat}" 
                                    Width="150"/>
            </DataGrid.Columns>
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="远程锁定" Click="LockClient_Click"/>
                    <MenuItem Header="远程解锁" Click="UnlockClient_Click"/>
                    <MenuItem Header="暂停计时" Click="PauseClient_Click"/>
                    <MenuItem Header="客户端设置" Click="EditClientSettings_Click"/>
                    <MenuItem Header="推送升级" Click="PushUpdate_Click"/>
                    <MenuItem Header="远程关机" Click="ShutdownClient_Click"/>
                </ContextMenu>
            </DataGrid.ContextMenu>
        </DataGrid>

        <!-- 状态栏 -->
        <StatusBar Grid.Row="4">
            <StatusBarItem>
                <TextBlock x:Name="StatusInfoText" 
                           Text="就绪"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
