<Window x:Class="ControlTimeService.LockWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="系统已锁定"
        WindowStyle="None"
        WindowState="Maximized"
        Topmost="True"
        Background="#EE000000"
        ShowInTaskbar="False">
    <Grid VerticalAlignment="Center"
            HorizontalAlignment="Center">
        <StackPanel>
            <TextBlock x:Name="TxtTitle"
                    Text="休息时间到了！"
                    FontSize="40"
                    Foreground="White"
                    HorizontalAlignment="Center"
                    Margin="20"/>
            <TextBlock x:Name="TxtTimer"
                    Text="剩余时间: 30:00"
                    FontSize="20"
                    Foreground="Gray"
                    HorizontalAlignment="Center"/>
            <PasswordBox x:Name="PassBox"
                    Width="200"
                    Margin="20"
                    Height="30"
                    VerticalContentAlignment="Center"/>
            <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="10">
                <Button x:Name="BtnUnlock"
                        Content="紧急解锁"
                        Click="Unlock_Click"
                        Width="100"
                        Height="30"
                        Margin="5"/>
                <Button x:Name="BtnShutdown"
                        Content="立即关机"
                        Click="BtnShutdown_Click"
                        Width="100"
                        Height="30"
                        Margin="5"
                        Visibility="Collapsed"/>
                <Button x:Name="BtnKill"
                        Content="退出程序"
                        Click="BtnKill_Click"
                        Width="100"
                        Height="30"
                        Margin="5"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>